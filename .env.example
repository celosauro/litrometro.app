# API SEFAZ/AL (Script de coleta - configurar como secret no GitHub)
SEFAZ_APP_TOKEN=seu-token-sefaz-aqui

# Para solicitar o token, envie e-mail para: api@sefaz.al.gov.br
# Informando: CPF, nome completo, nome do aplicativo/URL

# ============================================
# APIs de Geocodificação (Opcionais - Fallbacks)
# ============================================
# Usadas quando Nominatim não encontra o endereço

# OpenCage - 2.500 requisições/dia grátis
# Cadastro: https://opencagedata.com/users/sign_up
OPENCAGE_API_KEY=

# LocationIQ - 5.000 requisições/dia grátis
# Cadastro: https://locationiq.com/register
LOCATIONIQ_API_KEY=
