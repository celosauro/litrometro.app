# =============================================================================
# LITRÔMETRO - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# -----------------------------------------------------------------------------
# SEFAZ API - Obrigatório para coleta de dados
# Solicite em: api@sefaz.al.gov.br (CPF, nome, nome do app)
# -----------------------------------------------------------------------------
SEFAZ_APP_TOKEN=seu-token-sefaz-aqui

# -----------------------------------------------------------------------------
# Supabase - Banco de dados PostgreSQL
# Obtenha em: https://supabase.com/dashboard/project/SEU_PROJETO/settings/api
# -----------------------------------------------------------------------------

# URL do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave publishable (público - para frontend)
# Prefixo: sb_publishable_
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua_chave_aqui

# Chave secret (SECRETO - apenas para scripts de coleta)
# Prefixo: sb_secret_
SUPABASE_SECRET_KEY=sb_secret_sua_chave_aqui

# -----------------------------------------------------------------------------
# Processamento de Histórico
# -----------------------------------------------------------------------------

# Quantidade de dias de histórico para calcular min/max/médio (padrão: 30)
DIAS_HISTORICO=30

# -----------------------------------------------------------------------------
# Google Maps API - Validação de coordenadas
# Cadastro: https://console.cloud.google.com/apis/credentials
# -----------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui

# -----------------------------------------------------------------------------
# APIs de Geocodificação (Fallbacks opcionais)
# -----------------------------------------------------------------------------

# OpenCage - 2.500 requisições/dia grátis
# Cadastro: https://opencagedata.com/users/sign_up
OPENCAGE_API_KEY=

# LocationIQ - 5.000 requisições/dia grátis
# Cadastro: https://locationiq.com/register
LOCATIONIQ_API_KEY=
