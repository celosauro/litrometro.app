# Cache headers para Cloudflare Pages / Netlify
# GitHub Pages não suporta _headers (usa CDN próprio com cache)

# JSON de dados - cache de 30 minutos
/dados/atual.min.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600
  Content-Type: application/json; charset=utf-8

/dados/atual.json
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600
  Content-Type: application/json; charset=utf-8

# JSONs de municípios - cache de 30 minutos
/dados/municipios/*
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600
  Content-Type: application/json; charset=utf-8

# Assets estáticos (JS, CSS, imagens) - cache longo (1 ano)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML - sem cache, sempre busca a versão mais recente no deploy
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Service Worker - nunca cacheado pelo CDN (deve sempre ser buscado)
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/registerSW.js
  Cache-Control: no-cache, no-store, must-revalidate

# Default para arquivos não especificados
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  X-XSS-Protection: 1; mode=block
